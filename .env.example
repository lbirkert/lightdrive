# For SQLite (default — no setup required):
DATABASE_URL="file:./dev.db"

# For PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/lightdrive"

# Public-facing URL (required for CSRF protection in production)
# ORIGIN=http://localhost:3000

# Port (default 3000)
# PORT=3000

# Max request body size in bytes (default 524288 = 512 KB)
# BODY_SIZE_LIMIT=52428800
